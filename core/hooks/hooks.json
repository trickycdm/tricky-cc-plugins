{
  "description": "Automatic plan organization hooks",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/rename-plan.sh"
          }
        ]
      }
    ]
  }
}